<Window x:Class="DOANdotNET.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helper="clr-namespace:DOANdotNET.ViewModels.Helpers"
        xmlns:vm="clr-namespace:DOANdotNET.ViewModels"
        mc:Ignorable="d"
        Title="Đăng Nhập Hệ Thống" Height="643" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FocusManager.FocusedElement="{Binding ElementName=txtUserName}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0,0,0,-6">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f2027" Offset="0.0" />
                <GradientStop Color="#203a43" Offset="0.5" />
                <GradientStop Color="#2c5364" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="#F2FFFFFF" CornerRadius="15" Width="380"
                VerticalAlignment="Center" Padding="30,40,30,30" Margin="20">

            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <StackPanel>
                <Border Width="65" Height="65" Background="#3498DB" CornerRadius="35" 
                        HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3" Color="#3498DB"/>
                    </Border.Effect>
                    <TextBlock Text="P" Foreground="White" FontSize="36" FontWeight="Black" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                </Border>

                <TextBlock Text="HỆ THỐNG ĐỖ XE" FontSize="24" FontWeight="Bold"
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Quản lý bãi đỗ xe thông minh" FontSize="13"
                           Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Tên đăng nhập" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="2,0,0,8"/>
                <TextBox x:Name="txtUserName" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="2,0,0,8"/>

                <Grid Margin="0,0,0,10">
                    <PasswordBox x:Name="txtPassword" Panel.ZIndex="1"
                 helper:PasswordHelper.Attach="True"
                 helper:PasswordHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBox x:Name="txtVisiblePassword" Panel.ZIndex="2"
             Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             Visibility="{Binding IsChecked, ElementName=chkShowPass, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <CheckBox x:Name="chkShowPass" Content="👁 Hiện rõ mật khẩu" Margin="2,-5,0,15"
          Foreground="#7F8C8D" FontSize="12" Cursor="Hand" FontWeight="SemiBold"/>

               

                <TextBlock Text="{Binding ErrorMsg}" 
                           Foreground="#E74C3C" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"/>
                
                <Button Content="ĐĂNG NHẬP" IsDefault="True"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Height="45" Foreground="White" Margin="0,5,0,0"
                        FontWeight="Bold" FontSize="15" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2980B9" Offset="0.0"/>
                                        <GradientStop Color="#6DD5FA" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Border Background="#FEF9E7" CornerRadius="6" Padding="8,6" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Tài khoản thử nghiệm:" FontSize="10"
                   Foreground="#F39C12" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock FontSize="10" Foreground="#BDC3C7"
                   HorizontalAlignment="Center"
                   Text="admin/admin123  |  nv01/nv456  |  kh01/kh123"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
