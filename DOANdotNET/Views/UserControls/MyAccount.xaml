<UserControl x:Class="DOANdotNET.Views.UserControls.MyAccount"
             xmlns:helper="clr-namespace:DOANdotNET.ViewModels.Helpers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DOANdotNET.Views.UserControls"
             mc:Ignorable="d" d:DesignWidth="700" Height="599">

    <UserControl.Resources>
        <helper:PasswordConverter x:Key="PassConverter"/>
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#D3D1C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style TargetType="PasswordBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3498DB"/>
                                <Setter TargetName="bd" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F6FA">
        <Border Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="15" Padding="35,40,35,35">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#DCDDE1" Opacity="0.6"/>
            </Border.Effect>

            <StackPanel>
                <Border Width="70" Height="70" Background="#E6F1FB" CornerRadius="35" 
                        HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="👤" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#3498DB"/>
                </Border>

                <TextBlock Text="TÀI KHOẢN CỦA TÔI" FontSize="20" FontWeight="Black"
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding TenDangNhap, FallbackValue='Admin_User'}" FontSize="16"
                           Foreground="#3498DB" HorizontalAlignment="Center"
                           FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding VaiTroHienThi, FallbackValue='Quản trị viên'}" FontSize="13"
                           Foreground="#95A5A6" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <Separator Margin="0,0,0,25" Background="#EAECEE"/>

                <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,15"/>

                <TextBlock Text="Mật khẩu hiện tại:" FontWeight="SemiBold"
                           Foreground="#5F5E5A" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtOldPassword" Margin="0,0,0,15"/>

                <TextBlock Text="Mật khẩu mới:" FontWeight="SemiBold"
                           Foreground="#5F5E5A" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtNewPassword" Margin="0,0,0,25"/>

                <Button Content="XÁC NHẬN ĐỔI MẬT KHẨU"
        Command="{Binding ChangeMyPasswordCommand}"
        Style="{StaticResource ActionBtn}" Background="#27AE60" Margin="0,0,0,12">
                    <Button.CommandParameter>
                        <MultiBinding Converter="{StaticResource PassConverter}">
                            <Binding ElementName="txtOldPassword"/>
                            <Binding ElementName="txtNewPassword"/>
                        </MultiBinding>
                    </Button.CommandParameter>
                </Button>

                <TextBlock Text="Nhập mật khẩu cũ ở trên, mật khẩu mới ở dưới"
                           FontSize="11" Foreground="#BDC3C7"
                           HorizontalAlignment="Center" FontStyle="Italic"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>