<Window x:Class="DOANdotNET.Views.CheckIn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DOANdotNET.Views"
        mc:Ignorable="d"
        Title="Xe Vào Bãi (Check-In)" Height="514" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F6FA"
        FocusManager.FocusedElement="{Binding ElementName=txtTen}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#D3D1C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#378ADD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#E8EAED"/>
            <Setter Property="Foreground" Value="#5F5E5A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCDDE1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Border Background="White" CornerRadius="12" Padding="25"
                BorderBrush="#E8EAED" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#DCDDE1" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    
                    <RowDefinition Height="*"/>
                  
                    <RowDefinition Height="Auto"/>
                
                    <RowDefinition Height="Auto"/>
                    
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtTitle" Grid.Row="0" Text="ĐĂNG KÝ XE VÀO BÃI" FontSize="18" FontWeight="Black"
                           Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Tên khách hàng: *" FontWeight="SemiBold" Foreground="#5F5E5A" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTen"
         Text="{Binding TenKhachHang, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Số điện thoại:" FontWeight="SemiBold" Foreground="#5F5E5A" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtSDT"
         Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Biển số xe: *" FontWeight="SemiBold" Foreground="#5F5E5A" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtBienSo"
         Text="{Binding BienSoXe, UpdateSourceTrigger=PropertyChanged}"
         CharacterCasing="Upper" Foreground="#185FA5" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Loại xe:" FontWeight="SemiBold" Foreground="#5F5E5A" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding ListLoaiXe}"
          SelectedItem="{Binding SelectedLoaiXe}"
          DisplayMemberPath="TenLoaiXe"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Ảnh chụp camera / Cà vẹt" FontWeight="SemiBold" Foreground="#5F5E5A" Margin="0,0,0,5"/>

                        <Grid Height="180">
                            <Rectangle Stroke="#D3D1C7" StrokeThickness="1.5" RadiusX="8" RadiusY="8" 
                                       StrokeDashArray="4 4" Fill="#F8F9FA" SnapsToDevicePixels="True"/>

                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📷" FontSize="40" HorizontalAlignment="Center" Foreground="#BDC3C7"/>
                                    <TextBlock Text="Chưa có hình ảnh" FontSize="12" Foreground="#888780" Margin="0,10,0,0"/>
                                </StackPanel>

                                <Image x:Name="imgCamera" Source="{Binding ImagePath}" Stretch="UniformToFill" ClipToBounds="True">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,217,177" RadiusX="8" RadiusY="8"/>
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Grid>

                        <Button x:Name="btnUploadImage" Content="Tải ảnh lên" Style="{StaticResource GhostBtn}" 
                                Margin="0,10,0,0" Command="{Binding UploadImageCommand}"/>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="2"
        Background="#FCEBEB" CornerRadius="6"
        Padding="10,7" Margin="0,10,0,0"
        Visibility="{Binding HasError,
            Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMsg}"
               Foreground="#A32D2D"
               FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="HỦY BỎ" Width="100" IsCancel="True"
                            Style="{StaticResource ActionBtn}" Background="#95A5A6" Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <Button Content="XÁC NHẬN VÀO BÃI" Width="160" IsDefault="True"
                            Style="{StaticResource ActionBtn}" Background="#27AE60"
                            Command="{Binding ConfirmCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>