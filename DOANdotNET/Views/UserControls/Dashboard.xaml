<UserControl x:Class="DOANdotNET.Views.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DOANdotNET.ViewModels.UCViewModels">

    <UserControl.DataContext>
        <vm:DashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <TextBlock Text="📊 Dashboard" FontSize="24" FontWeight="Bold"
                       Foreground="#2C3E50" VerticalAlignment="Center"/>
            <Button Content="🔄 Làm mới" Command="{Binding RefreshCommand}"
                    Margin="16,0,0,0" Padding="12,6"
                    Background="#5D6D7E" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <!-- Hàng 1: 4 card -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,16">

            <!-- Tổng ô đỗ -->
            <Border Background="#2196F3" CornerRadius="10"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🅿" FontSize="28" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TongSlot}"
                               Foreground="White" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Tổng ô đỗ"
                               Foreground="#BBDEFB" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Đang có xe -->
            <Border Background="#F44336" CornerRadius="10"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🚗" FontSize="28" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding DangGui}"
                               Foreground="White" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Đang có xe"
                               Foreground="#FFCDD2" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Ô trống -->
            <Border Background="#4CAF50" CornerRadius="10"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="✅" FontSize="28" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding OTrong}"
                               Foreground="White" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Ô trống"
                               Foreground="#C8E6C9" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Doanh thu hôm nay -->
            <Border Background="#FF9800" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="💰" FontSize="28" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding DoanhThuHomNay, StringFormat={}{0:N0}}"
                               Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Doanh thu hôm nay"
                               Foreground="#FFE0B2" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- Hàng 2: 2 card -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="4">

            <!-- Lượt ra hôm nay -->
            <Border Background="#9C27B0" CornerRadius="10"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔄" FontSize="28" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LuotRaHomNay}"
                               Foreground="White" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Lượt ra hôm nay"
                               Foreground="#E1BEE7" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Đang đặt trước -->
            <Border Background="#00897B" CornerRadius="10"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="📅" FontSize="28" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SoDangDatTruoc}"
                               Foreground="White" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Đang đặt trước"
                               Foreground="#B2DFDB" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 2 ô trống giữ layout cân đối -->
            <Border/>
            <Border/>

        </UniformGrid>
    </Grid>
</UserControl>