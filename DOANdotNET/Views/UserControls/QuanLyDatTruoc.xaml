<UserControl x:Class="DOANdotNET.Views.UserControls.QuanLyDatTruoc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:DOANdotNET.ViewModels.UCViewModels"
             mc:Ignorable="d" d:DesignHeight="650" d:DesignWidth="1000">

    <UserControl.DataContext>
        <vm:QuanLyDatTruocViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#F4F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1"
                Padding="28,18">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Quản lý đặt trước" FontSize="18"
                               FontWeight="Bold" Foreground="#1A1A2E"/>
                    <TextBlock Text="Xác nhận hoặc hủy booking của khách hàng"
                               FontSize="12" Foreground="#9095A0" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Lọc trạng thái:" VerticalAlignment="Center"
                               FontSize="13" Foreground="#6B7280" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding DanhSachFilter}"
                              SelectedItem="{Binding FilterTrangThai}"
                              Width="150" Height="36"
                              VerticalContentAlignment="Center"
                              FontSize="13" Margin="0,0,10,0"/>
                    <Button Command="{Binding LamMoiCommand}"
                            Height="36" Padding="16,0"
                            Background="#378ADD" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8"
                                        Background="{TemplateBinding Background}">
                                    <TextBlock Text="🔄  Làm mới"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="13" FontWeight="SemiBold"
                                               Margin="16,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DANH SÁCH ── -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding DanhSach}"
                  SelectedItem="{Binding ChonBooking}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="None"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFBFD"
                  BorderThickness="0"
                  ColumnHeaderHeight="44"
                  RowHeight="52"
                  Margin="20,16,20,0"
                  Background="White">

            <DataGrid.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05"
                                  BlurRadius="16" ShadowDepth="2" Direction="270"/>
            </DataGrid.Effect>

            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderBrush" Value="#F0F2F8"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EBF3FB"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F9FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <!-- FIX: Xóa TextTransform="Uppercase" vì WPF không hỗ trợ -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1A1A2E"/>
                    <Setter Property="Foreground" Value="#9095A0"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="MÃ ĐẶT TRƯỚC"
                                    Binding="{Binding MaDatTruoc}"
                                    Width="175">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#378ADD"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="KHÁCH HÀNG"
                                    Binding="{Binding User.HoTen}"
                                    Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#1A1A2E"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="KHU VỰC"
                                    Binding="{Binding KhuVuc}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="LOẠI XE"
                                    Binding="{Binding LoaiXe.TenLoaiXe}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="THỜI GIAN ĐẾN"
                                    Binding="{Binding ThoiGianDenHienThi}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="SLOT"
                                    Binding="{Binding IDDoXe}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="GIÁ/GIỜ"
                                    Binding="{Binding GiaHienThi}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#16A34A"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Badge trạng thái -->
                <DataGridTemplateColumn Header="TRẠNG THÁI" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="20" Padding="10,4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#EAF7F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                <Setter Property="Background" Value="#FDECEA"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Chờ xử lý">
                                                <Setter Property="Background" Value="#FEF3E2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Hoàn thành">
                                                <Setter Property="Background" Value="#F3F4F6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding TrangThai}"
                                           FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TrangThai}" Value="Chờ xử lý">
                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TrangThai}" Value="Hoàn thành">
                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="NGÀY TẠO"
                                    Binding="{Binding NgayTao, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="135">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#9095A0"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── ACTION BAR ── -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E5E9F2" BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <!-- Chưa chọn dòng -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CoChonBooking}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="👆" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Chọn một booking để thực hiện hành động"
                               Foreground="#9095A0" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Đã chọn dòng -->
                <Grid Visibility="{Binding CoChonBooking, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                            Background="#EBF3FB" Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="👤" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Thông tin booking chọn -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="14" FontWeight="Bold" Foreground="#1A1A2E">
                                <Run Text="{Binding ChonBooking.MaDatTruoc}"/>
                            </TextBlock>
                            <TextBlock Text="  ·  " Foreground="#D1D5DB" FontSize="14"/>
                            <TextBlock Text="{Binding ChonBooking.User.HoTen}"
                                       FontSize="14" Foreground="#4B5563"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock FontSize="12" Foreground="#9095A0">
                                <Run Text="{Binding ChonBooking.KhuVuc}"/>
                                <Run Text=" · Slot: "/>
                                <Run Text="{Binding ChonBooking.IDDoXe}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding ChonBooking.ThoiGianDenHienThi}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding ChonBooking.GiaHienThi}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Nút hành động -->
                    <!-- FIX: Xóa Converter={x:Static BooleanToVisibilityConverter} không hợp lệ
                         Dùng Triggers trong ControlTemplate để handle IsEnabled thay thế -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding XacNhanCommand}"
                                IsEnabled="{Binding CanXacNhan}"
                                Height="38" Padding="20,0"
                                Background="#16A34A" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontSize="13" FontWeight="SemiBold"
                                Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8"
                                            Background="{TemplateBinding Background}">
                                        <TextBlock Text="✔  Xác nhận"
                                                   Margin="20,0" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding HuyCommand}"
                                IsEnabled="{Binding CanHuy}"
                                Height="38" Padding="20,0"
                                Background="#DC2626" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontSize="13" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8"
                                            Background="{TemplateBinding Background}">
                                        <TextBlock Text="✖  Hủy booking"
                                                   Margin="20,0" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
