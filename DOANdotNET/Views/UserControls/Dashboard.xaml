<UserControl x:Class="DOANdotNET.Views.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DOANdotNET.ViewModels.UCViewModels">
    <UserControl.DataContext>
        <vm:DashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <TextBlock Text="📊 Dashboard" FontSize="24" FontWeight="Bold"/>
            <Button Content="🔄 Làm mới" Command="{Binding RefreshCommand}"
                    Margin="16,0,0,0" Padding="12,4"/>
        </StackPanel>

        <!-- Hàng thẻ thống kê -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,16">

            <!-- Tổng ô đỗ -->
            <Border Background="#2196F3" CornerRadius="8" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🅿 Tổng ô đỗ" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding TongSlot}" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="ô" Foreground="#BBDEFB" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Đang có xe -->
            <Border Background="#F44336" CornerRadius="8" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🚗 Đang có xe" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding DangGui}" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="xe" Foreground="#FFCDD2" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Ô trống -->
            <Border Background="#4CAF50" CornerRadius="8" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="✅ Ô trống" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding OTrong}" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="ô" Foreground="#C8E6C9" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Doanh thu hôm nay -->
            <Border Background="#FF9800" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="💰 Doanh thu hôm nay" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding DoanhThuHomNay, StringFormat={}{0:N0}}"
                               Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="đồng" Foreground="#FFE0B2" FontSize="12"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Hàng thứ 2 -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="4">
            <Border Background="#9C27B0" CornerRadius="8" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔄 Lượt ra hôm nay" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding LuotRaHomNay}" Foreground="White"
                               FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="lượt" Foreground="#E1BEE7" FontSize="12"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>