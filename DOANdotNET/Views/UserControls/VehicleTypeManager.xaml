<UserControl x:Class="DOANdotNET.Views.UserControls.VehicleTypeManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DOANdotNET.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="550" Width="905">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background"               Value="#F8F9FA"/>
            <Setter Property="BorderBrush"              Value="#DDE1E7"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3498DB"/>
                                <Setter TargetName="bd" Property="Background"  Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="BorderBrush"     Value="#F5F6FA"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F8F9FA"/>
            <Setter Property="Foreground"      Value="#7F8C8D"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="BorderBrush"     Value="#ECF0F1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F5F6FA" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== TIÊU ĐỀ ===== -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Quản lý loại xe"
                       FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text="Quản lý các loại xe và mức phí gửi xe tương ứng"
                       FontSize="12" Foreground="#95A5A6" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- ===== FORM THÊM/SỬA ===== -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                BorderBrush="#E8EAED" BorderThickness="1"
                Margin="0,0,0,14">
            <StackPanel>

                <!-- Header form -->
                <Border Padding="16,11" BorderBrush="#F1F1F1" BorderThickness="0,0,0,1"
                        Background="#FAFBFC">
                    <TextBlock Text="{Binding FormTitle}"
                               FontSize="13" FontWeight="SemiBold" Foreground="#34495E"/>
                </Border>

                <!-- Fields -->
                <Grid Margin="16,14,16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Mã loại xe -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Margin="0,0,0,5" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#34495E">
                            <Run Text="Mã loại xe"/>
                            <Run Text=" *" Foreground="#E74C3C"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource InputStyle}"
                                 Text="{Binding MaLoaiXe, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Tên loại xe -->
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Margin="0,0,0,5" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#34495E">
                            <Run Text="Tên loại xe"/>
                            <Run Text=" *" Foreground="#E74C3C"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource InputStyle}"
                                 Text="{Binding TenLoaiXe, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Phí/giờ -->
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Margin="0,0,0,5" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#34495E">
                            <Run Text="Phí/giờ (VNĐ)"/>
                            <Run Text=" *" Foreground="#E74C3C"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource InputStyle}"
                                 Text="{Binding PhiMoiGio, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Nút -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <Button Content="✓  Thêm mới"
                                Command="{Binding ThemMoiCommand}"
                                Style="{StaticResource ActionBtn}"
                                Background="#2ECC71" Margin="0,0,6,0" Width="83"/>
                        <Button Content="↑  Cập nhật"
                                Command="{Binding CapNhatCommand}"
                                Style="{StaticResource ActionBtn}"
                                Background="#3498DB" Margin="0,0,6,0" Width="80"/>
                        <Button Content="✕  Làm trống"
                                Command="{Binding LamTrongCommand}"
                                Style="{StaticResource ActionBtn}"
                                Background="#BDC3C7" Width="82"/>
                    </StackPanel>
                </Grid>

                <!-- Thông báo lỗi -->
                <TextBlock Text="{Binding ErrorMsg}"
                           Foreground="#E74C3C" FontSize="12"
                           Margin="16,0,16,12"
                           Visibility="{Binding HasError,
                               Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- ===== BẢNG DANH SÁCH ===== -->
        <Border Grid.Row="2" Background="White" CornerRadius="10"
                BorderBrush="#E8EAED" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header bảng -->
                <Border Grid.Row="0" Padding="16,10"
                        Background="#FAFBFC"
                        BorderBrush="#F1F1F1" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Danh sách loại xe"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#34495E"/>
                        <TextBlock Text="{Binding ListLoaiXe.Count,
                                                   StringFormat={}{0} loại xe}"
                                   FontSize="11" Foreground="#95A5A6"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ListLoaiXe}"
                          SelectedItem="{Binding SelectedLoaiXe}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          Background="White"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F5F6FA"
                          RowHeight="40"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          SelectionMode="Single">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Mã loại xe"
                            Binding="{Binding MaLoaiXe}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"      Value="14,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                    <Setter Property="Foreground"   Value="#2C3E50"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tên loại xe"
                            Binding="{Binding TenLoaiXe}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"      Value="14,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Phí/giờ"
                            Binding="{Binding PhiMoiGio, StringFormat={}{0:N0} đ}"
                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"      Value="14,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                    <Setter Property="Foreground"   Value="#639922"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Số xe đang gửi"
                            Binding="{Binding SoXeDangGui}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"      Value="14,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground"   Value="#2C3E50"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Cột thao tác -->
                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="6,0">
                                        <Button Content="Sửa"
                                                Command="{Binding DataContext.SuaCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Height="28" Width="55"
                                                Background="#3498DB" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                FontSize="12" FontWeight="SemiBold"
                                                Margin="0,0,6,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" CornerRadius="5"
                                                            Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="Xóa"
                                                Command="{Binding DataContext.XoaCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Height="28" Width="55"
                                                Background="#E74C3C" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                FontSize="12" FontWeight="SemiBold">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" CornerRadius="5"
                                                            Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
