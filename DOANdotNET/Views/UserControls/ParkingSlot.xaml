<UserControl x:Class="DOANdotNET.Views.UserControls.ParkingSlot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DOANdotNET.Views.UserControls"
             mc:Ignorable="d" 
                        d:DesignHeight="90" d:DesignWidth="90">

    <Border Width="86" Height="86" CornerRadius="10"
            BorderThickness="1.5" Cursor="Hand">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background"   Value="#EAF3DE"/>
                <Setter Property="BorderBrush"  Value="#97C459"/>
                <Style.Triggers>

                    <DataTrigger Binding="{Binding TrangThai}" Value="Đang gửi">
                        <Setter Property="Background"  Value="#FCEBEB"/>
                        <Setter Property="BorderBrush" Value="#F09595"/>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="#378ADD"/>
                        <Setter Property="BorderThickness" Value="3"/>
                    </DataTrigger>

                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Icon trạng thái -->
            <TextBlock HorizontalAlignment="Center"
                       FontSize="18" Margin="0,0,0,3">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <!-- Trống: icon P -->
                        <Setter Property="Text"       Value="P"/>
                        <Setter Property="Foreground" Value="#3B6D11"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TrangThai}" Value="Đang gửi">
                                <Setter Property="Text"       Value="🚗"/>
                                <Setter Property="Foreground" Value="#A32D2D"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Mã vị trí -->
            <TextBlock Text="{Binding IDDoXe}"
                       FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#27500A"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TrangThai}" Value="Đang gửi">
                                <Setter Property="Foreground" Value="#791F1F"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Biển số xe (chỉ hiện khi có xe) -->
            <TextBlock Text="{Binding BienSoXe}"
                       FontSize="9" HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="4,2,4,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#3B6D11"/>
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TrangThai}" Value="Đang gửi">
                                <Setter Property="Foreground" Value="#A32D2D"/>
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </Border>
</UserControl>