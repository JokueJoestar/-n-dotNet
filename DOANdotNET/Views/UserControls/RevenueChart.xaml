<UserControl x:Class="DOANdotNET.Views.UserControls.RevenueChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DOANdotNET.ViewModels.UCViewModels">
    <UserControl.DataContext>
        <vm:RevenueChartViewModel />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TIÊU ĐỀ -->
            <TextBlock Grid.Row="0"
                       Text="📊 Biểu Đồ &amp; Thống Kê Doanh Thu"
                       FontSize="22" FontWeight="Bold" Foreground="#2C3E50"
                       Margin="0,0,0,16"/>

            <!-- 4 THẺ TỔNG QUAN -->
            <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,16">
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Tổng giao dịch" Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock Text="{Binding TongGiaoDich}" FontSize="32" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Đã thanh toán" Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock Text="{Binding DaThanhToan}" FontSize="32" FontWeight="Bold" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Doanh thu (theo lọc)" Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} đ}"
                                   FontSize="22" FontWeight="Bold" Foreground="#E67E22"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Xe đang trong bãi" Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock Text="{Binding XeTrongBai}" FontSize="32" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- BỘ LỌC -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="14"
                    Margin="0,0,0,16">
                <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#7F8C8D"/>
                    <DatePicker SelectedDate="{Binding TuNgay}" Width="130" Margin="0,0,16,0"/>
                    <TextBlock Text="đến:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#7F8C8D"/>
                    <DatePicker SelectedDate="{Binding DenNgay}" Width="130" Margin="0,0,16,0"/>
                    <ComboBox ItemsSource="{Binding DanhSachLoaiXe}"
                              SelectedItem="{Binding LoaiXeChon}"
                              DisplayMemberPath="TenLoaiXe"
                              Width="130" Margin="0,0,16,0"
                              VerticalContentAlignment="Center"/>
                    <Button Content="🔍 Lọc" Command="{Binding LocCommand}"
                            Padding="16,6" Background="#3498DB" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="🔄 Làm mới" Command="{Binding RefreshCommand}"
                            Padding="16,6" Background="#95A5A6" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="📥 Xuất Excel" Command="{Binding XuatExcelCommand}"
                            Padding="16,6" Background="#27AE60" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- BIỂU ĐỒ + 3 THẺ MINI -->
            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="20"
                    Margin="0,0,0,16">
                <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <!-- CỘT TRÁI: THANH BAR -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Doanh thu theo ngày (đồng)"
                                   FontWeight="SemiBold" Foreground="#2C3E50"
                                   Margin="0,0,0,12"/>

                        <!-- Thông báo khi không có dữ liệu -->
                        <TextBlock Text="Không có dữ liệu trong khoảng thời gian này."
                                   Foreground="#95A5A6" FontStyle="Italic" FontSize="13"
                                   Margin="0,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoChartData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding ChartItems}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoChartData}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Ngay}"
                                                   VerticalAlignment="Center"
                                                   Foreground="#7F8C8D" FontSize="12"/>
                                        <Border Grid.Column="1" Height="26" CornerRadius="4"
                                                Background="#3498DB" Margin="4,0"
                                                HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DoanhThu, StringFormat={}{0:N0}đ}"
                                                   VerticalAlignment="Center"
                                                   Foreground="#2C3E50" FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- CỘT PHẢI: 3 THẺ MINI -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <Border Background="#2C3E50" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="💰 Tổng doanh thu" Foreground="#BDC3C7" FontSize="11"/>
                                <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0}}"
                                           Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                                <TextBlock Text="đồng" Foreground="#7F8C8D" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#8E44AD" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="🚗 Tổng lượt xe" Foreground="#D7BDE2" FontSize="11"/>
                                <TextBlock Text="{Binding TongLuotXe}"
                                           Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                                <TextBlock Text="lượt" Foreground="#D7BDE2" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#16A085" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="📅 TB / ngày" Foreground="#A2D9CE" FontSize="11"/>
                                <TextBlock Text="{Binding TrungBinhNgay, StringFormat={}{0:N0}}"
                                           Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                                <TextBlock Text="đồng" Foreground="#A2D9CE" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BẢNG CHI TIẾT GIAO DỊCH -->
            <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="16"
                    Margin="0,0,0,16">
                <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Chi tiết giao dịch" FontWeight="SemiBold"
                                   Foreground="#2C3E50" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SoGiaoDichHienThi, StringFormat=Hiển thị {0} giao dịch}"
                                   HorizontalAlignment="Right" Foreground="#95A5A6"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding DanhSachGiaoDich}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="White"
                              BorderThickness="0"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F9FA"
                              CanUserResizeRows="False"
                              MaxHeight="280"
                              SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E8EAED"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã GD"          Binding="{Binding MaGiaoDich}"   Width="130"/>
                            <DataGridTextColumn Header="Vị trí"         Binding="{Binding IDDoXe}"       Width="70"/>
                            <DataGridTextColumn Header="Khách hàng"     Binding="{Binding TenKhachHang}" Width="*"/>
                            <DataGridTextColumn Header="Biển số"        Binding="{Binding BienSoXe}"     Width="100"/>
                            <DataGridTextColumn Header="Giờ vào"        Binding="{Binding ThoiGianVao, StringFormat=dd/MM HH:mm}" Width="100"/>
                            <DataGridTextColumn Header="Giờ ra"         Binding="{Binding ThoiGianRaHienThi}" Width="100"/>
                            <DataGridTextColumn Header="Trạng thái"     Binding="{Binding TrangThai}"    Width="100"/>
                            <DataGridTextColumn Header="Thành tiền (đ)" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- FOOTER -->
            <Border Grid.Row="5" Background="White" CornerRadius="8" Padding="14,10">
                <Border.Effect><DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/></Border.Effect>
                <Grid>
                    <TextBlock Text="{Binding FooterLeft}" Foreground="#7F8C8D"
                               FontSize="13" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Tổng doanh thu: " Foreground="#7F8C8D"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} đ}"
                                   Foreground="#E67E22" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>